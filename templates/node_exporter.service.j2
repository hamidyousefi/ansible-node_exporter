[Unit]
Description=Node Exporter
Wants=network-online.target
After=network-online.target

[Service]
User=node_exporter
Group=node_exporter
Type=simple
ExecStart=/usr/local/bin/node_exporter --web.listen-address={{ (ansible_all_ipv4_addresses | select('match', '^10\\.0\\.') | list | first) | default('') }}:9100

[Install]
WantedBy=multi-user.target
